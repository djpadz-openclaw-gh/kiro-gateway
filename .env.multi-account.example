# Multi-Account Kiro Gateway - Environment Variables Example

# ============================================================================
# MULTI-ACCOUNT CONFIGURATION
# ============================================================================

# JSON array of account configurations
# This is the primary way to configure multiple accounts
KIRO_ACCOUNTS_JSON='[
  {
    "id": "dj",
    "name": "Dj Account",
    "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
    "profileArn": "arn:aws:codewhisperer:us-east-1:123456789012:profile/default",
    "region": "us-east-1",
    "overage": false
  },
  {
    "id": "sherra",
    "name": "Sherra Account (Overage)",
    "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
    "profileArn": "arn:aws:codewhisperer:us-east-1:123456789012:profile/default",
    "region": "us-east-1",
    "overage": true
  }
]'

# Health check interval in hours (default: 1)
KIRO_HEALTH_CHECK_INTERVAL_HOURS=1

# ============================================================================
# PROXY SERVER SETTINGS (Optional)
# ============================================================================

# VPN/Proxy URL for accessing Kiro API through a proxy server
# Supports HTTP and SOCKS5 protocols
# Examples:
#   VPN_PROXY_URL=http://127.0.0.1:7890
#   VPN_PROXY_URL=socks5://127.0.0.1:1080
#   VPN_PROXY_URL=http://user:password@proxy.company.com:8080
VPN_PROXY_URL=

# ============================================================================
# SERVER SETTINGS
# ============================================================================

# Server host (default: 0.0.0.0 - listen on all interfaces)
# Use "127.0.0.1" to only allow local connections
SERVER_HOST=0.0.0.0

# Server port (default: 8000)
# Can be overridden by CLI: python main.py --port 9000
SERVER_PORT=8000

# ============================================================================
# PROXY AUTHENTICATION
# ============================================================================

# API key for proxy access (clients must pass it in Authorization header)
# Generate a secure random string for production
PROXY_API_KEY=my-super-secret-password-123

# ============================================================================
# LOGGING
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# SINGLE-ACCOUNT MODE (Fallback if KIRO_ACCOUNTS_JSON not set)
# ============================================================================

# If KIRO_ACCOUNTS_JSON is not set, gateway falls back to single-account mode
# using these environment variables

# Refresh token for single account
# REFRESH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Profile ARN for single account (optional)
# PROFILE_ARN=arn:aws:codewhisperer:us-east-1:123456789012:profile/default

# AWS region for single account (default: us-east-1)
# KIRO_REGION=us-east-1

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================

# Path to credentials file (alternative to REFRESH_TOKEN)
# KIRO_CREDS_FILE=~/.aws/sso/cache/kiro-auth-token.json

# Path to kiro-cli database (alternative to REFRESH_TOKEN)
# KIRO_CLI_DB_FILE=~/.local/share/kiro-cli/data.sqlite3

# Streaming read timeout in seconds (default: 600)
# STREAMING_READ_TIMEOUT=600

# First token timeout in seconds (default: 300)
# FIRST_TOKEN_TIMEOUT=300

# ============================================================================
# USAGE EXAMPLES
# ============================================================================

# Example 1: Multi-account with environment variables
# export KIRO_ACCOUNTS_JSON='[...]'
# export KIRO_HEALTH_CHECK_INTERVAL_HOURS=1
# export PROXY_API_KEY="my-super-secret-password-123"
# python main.py

# Example 2: Multi-account with configuration file
# export KIRO_ACCOUNTS_FILE=./kiro-accounts.json
# export PROXY_API_KEY="my-super-secret-password-123"
# python main.py

# Example 3: Single-account mode (backward compatible)
# export REFRESH_TOKEN="..."
# export PROFILE_ARN="..."
# export PROXY_API_KEY="my-super-secret-password-123"
# python main.py

# Example 4: Docker with multi-account
# docker run -d \
#   -p 8000:8000 \
#   -e KIRO_ACCOUNTS_JSON='[...]' \
#   -e KIRO_HEALTH_CHECK_INTERVAL_HOURS=1 \
#   -e PROXY_API_KEY="my-super-secret-password-123" \
#   --name kiro-gateway-multi \
#   ghcr.io/jwadow/kiro-gateway:latest

# Example 5: Systemd with multi-account
# Create /etc/kiro-gateway/8000.env with:
# KIRO_ACCOUNTS_JSON='[...]'
# KIRO_HEALTH_CHECK_INTERVAL_HOURS=1
# PROXY_API_KEY="my-super-secret-password-123"
# Then: sudo systemctl start kiro-gateway@8000.service
